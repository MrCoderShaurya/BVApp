<?xml version='1.0' encoding='utf-8'?>
<widget id="com.mrcodershaurya.meetnotes" version="1.0.0"
    xmlns="http://www.w3.org/ns/widgets"
    xmlns:cdv="http://cordova.apache.org/ns/1.0">

    <name>Meet Notes App</name>
    <icon src="www/img/zmicon.png" />
    <description>
        Zoom, Google Meet and Notes App for legacy iOS devices.
    </description>
    <author email="mrcodershaurya@gmail.com" href="https://github.com/MrCoderShaurya">
        MrCoderShaurya
    </author>

    <content src="index.html" />

    <!-- Network access -->
    <access origin="*" />
    <allow-navigation href="https://meet.google.com/*" />
    <allow-navigation href="https://*.meet.google.com/*" />
    <allow-navigation href="https://zoom.us/*" />
    <allow-navigation href="https://*.zoom.us/*" />
    <allow-navigation href="file://*/*" />
    <allow-navigation href="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="tel:*" />
    <allow-intent href="sms:*" />
    <allow-intent href="mailto:*" />
    <allow-intent href="geo:*" />
    <allow-intent href="zoomus:*" />
    <allow-intent href="gmeet:*" />

    <!-- Android -->
    <platform name="android">
        <allow-intent href="market:*" />
    </platform>

    <!-- iOS — targets iOS 9.3 for legacy device compatibility -->
    <platform name="ios">
        <allow-intent href="itms:*" />
        <allow-intent href="itms-apps:*" />
        <icon src="www/img/zmicon.png" />
        <preference name="deployment-target" value="9.0" />
        <preference name="AllowInlineMediaPlayback" value="true" />
        <preference name="MediaPlaybackRequiresUserAction" value="false" />
        <preference name="UIWebViewDecelerationSpeed" value="fast" />
        <preference name="DisallowOverscroll" value="true" />
        <preference name="UIWebViewBounce" value="false" />
        
        <!-- Crucial settings to enable pinch-to-zoom -->
        <preference name="EnableViewportScale" value="true" />
    </platform>

</widget>
