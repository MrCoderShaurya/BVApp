<?xml version='1.0' encoding='utf-8'?>
<widget id="com.bvapp.bhaktivedanta" version="1.0.0"
    xmlns="http://www.w3.org/ns/widgets"
    xmlns:cdv="http://cordova.apache.org/ns/1.0">

    <name>Bhakti Vedanta App</name>
    <icon src="www/img/bvicon.png" />
    <description>
        Bhakti Vedanta App - A spiritual resource app for audio, calendar, and scripture.
    </description>
    <author email="mrcodershaurya@gmail.com" href="https://github.com/MrCoderShaurya">
        MrCoderShaurya
    </author>

    <content src="index.html" />

    <!-- Network access -->
    <access origin="*" />
    <allow-navigation href="https://audio.iskcondesiretree.com/*" />
    <allow-navigation href="https://vedabase.io/*" />
    <allow-navigation href="http://*.vaisnavacalendar.com/*" />
    <allow-navigation href="http://www.vaisnavacalendar.com/*" />
    <allow-navigation href="file://*/*" />
    <allow-navigation href="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="tel:*" />
    <allow-intent href="sms:*" />
    <allow-intent href="mailto:*" />
    <allow-intent href="geo:*" />

    <!-- Android -->
    <platform name="android">
        <allow-intent href="market:*" />
    </platform>

    <!-- iOS — targets iOS 9.3 for legacy device compatibility -->
    <platform name="ios">
        <allow-intent href="itms:*" />
        <allow-intent href="itms-apps:*" />
        <icon src="www/img/bvicon.png" />
        <preference name="deployment-target" value="9.0" />
        <preference name="AllowInlineMediaPlayback" value="true" />
        <preference name="MediaPlaybackRequiresUserAction" value="false" />
    </platform>

</widget>
