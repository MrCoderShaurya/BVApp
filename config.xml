<?xml version='1.0' encoding='utf-8'?>
<widget id="com.bvapp.bhaktivedanta" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>Bhakti Vedanta App</name>
    <icon src="BVicon.png" />
    <description>
        Bhakti Vedanta App - A spiritual resource app for audio, calendar, and scripture.
    </description>
    <author email="mrcodershaurya@gmail.com" href="https://github.com/MrCoderShaurya">
        MrCoderShaurya
    </author>
    <content src="index.html" />
    <plugin name="cordova-plugin-whitelist" spec="1" />
    <access origin="*" />
    <allow-navigation href="https://audio.iskcondesiretree.com/*" />
    <allow-navigation href="https://vedabase.io/*" />
    <allow-navigation href="http://*.vaisnavacalendar.com/*" />
    <allow-navigation href="http://www.vaisnavacalendar.com/*" />
    <allow-navigation href="file://*/*" />
    <allow-navigation href="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="tel:*" />
    <allow-intent href="sms:*" />
    <allow-intent href="mailto:*" />
    <allow-intent href="geo:*" />
    <platform name="android">
        <allow-intent href="market:*" />
    </platform>
    <platform name="ios">
        <allow-intent href="itms:*" />
        <allow-intent href="itms-apps:*" />
        <!-- iOS 9.3.5 jailbroken iPad compatibility settings -->
        <preference name="deployment-target" value="9.3" />
        <preference name="AllowInlineMediaPlayback" value="true" />
        <preference name="MediaPlaybackRequiresUserAction" value="false" />
        <preference name="UIWebViewDecelerationSpeed" value="fast" />
    </platform>
</widget>
